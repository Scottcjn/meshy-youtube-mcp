# Meshy.ai API key — required for 3D generation. https://www.meshy.ai/
MESHY_API_KEY=

# YouTube OAuth — paths to your OAuth client and the token minted by
# `python -m meshy_youtube.authorize`. Both default to ~/.config/meshy-youtube-mcp/.
# YOUTUBE_CLIENT_SECRET_FILE=/home/you/.config/meshy-youtube-mcp/client_secret.json
# YOUTUBE_TOKEN_FILE=/home/you/.config/meshy-youtube-mcp/token.json

# Where intermediate files (glb, frames, mp4) are written.
# Optional; defaults to a fresh temp dir per run.
# MESHY_YOUTUBE_WORKDIR=/tmp/meshy-youtube
